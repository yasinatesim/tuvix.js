{
  "name": "@tuvix.js/chatbot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts --format esm --dts --outDir dist",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "seed": "tsx data/seed.ts",
    "export-hf": "tsx scripts/export-huggingface.ts",
    "generate-dataset": "tsx scripts/generate-dataset.ts",
    "seed:clear": "tsx data/seed-clear.ts"
  },
  "dependencies": {
    "chromadb": "^1.9.2",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "helmet": "^8.1.0",
    "marked": "^14.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/helmet": "^4.0.0",
    "@types/node": "^20.0.0",
    "@types/supertest": "^7.2.0",
    "esbuild": "^0.28.0",
    "supertest": "^7.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "vitest": "^2.0.0"
  }
}
