{
	"name": "@tuvix.js/event-bus",
	"version": "0.1.2",
	"description": "Lightweight event bus for inter-app communication in Tuvix.js",
	"main": "dist/index.cjs",
	"module": "dist/index.mjs",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "vitest run",
		"test:watch": "vitest watch",
		"clean": "rm -rf dist",
		"check-types": "tsc --noEmit",
		"lint": "eslint src/"
	},
	"keywords": [
		"event-bus",
		"pubsub",
		"microfrontend",
		"tuvix"
	],
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"sideEffects": false
}