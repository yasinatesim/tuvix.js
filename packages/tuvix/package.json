{
	"name": "tuvix.js",
	"version": "0.1.5",
	"description": "A lightweight microfrontend framework for building scalable, independently deployable frontend applications",
	"main": "dist/index.cjs",
	"module": "dist/index.mjs",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"clean": "rm -rf dist",
		"test": "vitest run",
		"test:watch": "vitest",
		"check-types": "tsc --noEmit"
	},
	"dependencies": {
		"@tuvix.js/core": "workspace:*",
		"@tuvix.js/router": "workspace:*",
		"@tuvix.js/event-bus": "workspace:*",
		"@tuvix.js/loader": "workspace:*",
		"@tuvix.js/sandbox": "workspace:*"
	},
	"keywords": [
		"microfrontend",
		"micro-frontend",
		"framework",
		"module-federation",
		"web-components",
		"orchestrator",
		"frontend-architecture"
	],
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"sideEffects": false,
	"homepage": "https://github.com/yasinatesim/tuvix.js",
	"repository": {
		"type": "git",
		"url": "https://github.com/yasinatesim/tuvix.js"
	}
}