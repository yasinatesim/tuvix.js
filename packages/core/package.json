{
	"name": "@tuvix.js/core",
	"version": "0.4.2",
	"description": "Core orchestrator for Tuvix.js microfrontend framework",
	"main": "dist/index.cjs",
	"module": "dist/index.mjs",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "vitest run",
		"test:watch": "vitest watch",
		"clean": "rm -rf dist",
		"check-types": "tsc --noEmit"
	},
	"dependencies": {
		"@tuvix.js/event-bus": "workspace:*",
		"@tuvix.js/loader": "workspace:*",
		"@tuvix.js/router": "workspace:*"
	},
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"sideEffects": false
}