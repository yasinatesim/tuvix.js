{
	"name": "create-tuvix-app",
	"version": "0.1.2",
	"description": "CLI scaffolding tool for Tuvix.js microfrontend projects",
	"bin": {
		"create-tuvix-app": "dist/index.js"
	},
	"main": "dist/index.js",
	"files": [
		"dist",
		"templates"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "vitest run",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [
		"cli",
		"scaffold",
		"microfrontend",
		"tuvix",
		"create-app"
	],
	"license": "MIT",
	"dependencies": {
		"tar": "^7.5.11"
	},
	"devDependencies": {
		"@types/tar": "^6.1.13"
	}
}
